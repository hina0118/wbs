{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WBS進捗管理",
  "version": "1.0.9",
  "identifier": "com.wbs.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "WBS 進捗管理",
        "width": 1024,
        "height": 768
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEMzNjlCREIxOEYxNEY3RjQKUldUMDl4U1BzYjFwdzhsdyszenROeWtuaUpkMEdFMXRrQ0JOSGd5dGFwM2pIdXhvMjVxQ2Z1eDkK",
      "endpoints": [
        "https://github.com/hina0118/wbs/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": "v1Compatible",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
